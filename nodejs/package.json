{
    "name": "@quantum-auth/jwt-client",
    "version": "1.0.0",
    "description": "Quantum JWT client library for Node.js — uses quantum-derived entropy from Redis to sign and verify JWTs.",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "scripts": {
        "build": "tsc",
        "test": "jest --forceExit",
        "lint": "tsc --noEmit"
    },
    "keywords": [
        "jwt",
        "quantum",
        "redis",
        "authentication"
    ],
    "license": "MIT",
    "dependencies": {
        "ioredis": "^5.3.2",
        "jsonwebtoken": "^9.0.2",
        "uuid": "^9.0.0",
        "winston": "^3.11.0"
    },
    "devDependencies": {
        "@types/jsonwebtoken": "^9.0.5",
        "@types/uuid": "^9.0.7",
        "@types/node": "^20.11.5",
        "typescript": "^5.3.3",
        "jest": "^29.7.0",
        "ts-jest": "^29.1.1",
        "@types/jest": "^29.5.11",
        "ioredis-mock": "^8.9.0"
    },
    "jest": {
        "preset": "ts-jest",
        "testEnvironment": "node",
        "roots": [
            "<rootDir>/tests"
        ]
    }
}